#!/usr/bin/env bash
#
# boring — dev container launcher for wrapped apps
# https://github.com/steig/boring
#
VERSION="0.7.0"
#
# Usage:
#   boring open <git-url|.>                          Clone or attach a boring-enabled repo
#   boring run "<prompt>" --profile <name> [--repo <path>]
#                                                    Headless one-shot Claude (ARD-0013)
#   boring wip {start|commit|discard} <profile|.>    WIP-branch lifecycle (ARD-0022 §3)
#   boring save <profile|.>                          Promote WIP branch to PR (ARD-0022 §7)
#   boring proxy <subcommand>                        Host-side reverse proxy (ARD-0021, v1.x)
#   boring doctor                                    Diagnose environment
#   boring version                                   Print version
#   boring help                                      Print this help
#

set -euo pipefail

# Resolve BASH_SOURCE through symlinks so SCRIPT_DIR points at the real
# install tree (lib/ + templates/) even when invoked via a ~/.local/bin
# symlink that install.sh creates. Plain `dirname "${BASH_SOURCE[0]}"`
# returns the symlink's directory and breaks sibling-dir lookups.
# `readlink -f` exists on both BSD (macOS) and GNU (Linux) readlink.
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
LIB_DIR="${BORING_LIB_DIR:-$SCRIPT_DIR/lib}"

# ============================================================================
# Source library modules
# ============================================================================

source "$LIB_DIR/core.sh"
source "$LIB_DIR/secrets.sh"
source "$LIB_DIR/dbx.sh"
source "$LIB_DIR/devcontainer.sh"
source "$LIB_DIR/profile.sh"
source "$LIB_DIR/compose.sh"
source "$LIB_DIR/guardrails.sh"
source "$LIB_DIR/egress.sh"
source "$LIB_DIR/doctor.sh"
source "$LIB_DIR/audit.sh"
source "$LIB_DIR/saver.sh"

# ============================================================================
# Globals
# ============================================================================
# _cmd_open_resolve_secrets writes the resolved `--remote-env KEY=VALUE` argv
# pairs into this array (it's then consumed by `devcontainer_up`). We use a
# named global instead of `local -n` (namerefs, bash 4.3+) so the script
# works on macOS's default `/bin/bash` 3.2. A temp-file return would put
# resolved secrets on disk and a process-sub return would lose `die`'s
# exit-1 to the subshell. A global is the simplest portable option that
# keeps secrets in memory only and preserves fail-fast behavior.
BORING_REMOTE_ENV_ARGS=()

# ============================================================================
# Subcommands
# ============================================================================

cmd_open() {
  # ARD-0004 + ARD-0007 v0.2 + ARD-0009 guardrails + ARD-0010 audit + ARD-0011
  # egress. Resolves secret URIs via lib/secrets.sh; emits .devcontainer/
  # docker-compose.yml + devcontainer.json including the boring-runtime RO
  # mount + audit FIFO + egress allowlist; spawns the host-side audit collector;
  # brings container up via devcontainer CLI passing resolved secrets via
  # --remote-env (never written to disk); verifies setup marker post-up.
  #
  # Flags:
  #   --learn-mode  Per ARD-0011, install iptables LOG (audit-only) rules
  #                 instead of REJECT. On Ctrl-C, parse the logs and emit a
  #                 proposed egress.allow diff for the user to paste.
  local target=""
  local learn_mode=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --learn-mode) learn_mode=1; shift ;;
      --) shift; break ;;
      -*) die "boring open: unknown flag $1" ;;
      *) [[ -z "$target" ]] && target="$1" || die "boring open: extra argument $1"; shift ;;
    esac
  done
  target="${target:-.}"

  if [[ "$target" =~ ^(git@|https?://) ]]; then
    die "boring open: URL cloning not yet implemented for v1. Clone manually, then run 'boring open <path>'."
  fi

  [[ -d "$target" ]] || die "boring open: not a directory: $target"
  local repo
  repo="$(cd "$target" && pwd)"

  log_step "Loading profile from $repo/.boring/profile.yaml"
  local profile_json
  profile_json="$(profile_load "$repo")"

  local name
  name="$(jq -r '.name' <<<"$profile_json")"
  log_info "Profile: $name"

  # Stash for the SIGINT/SIGTERM/EXIT trap below — the trap fires in a
  # context where local variables of this function aren't visible.
  BORING_OPEN_PROFILE_NAME="$name"
  # INT/TERM: graceful tear-down + non-zero exit (130 = SIGINT convention).
  trap '_cmd_open_stop_audit_collector "$BORING_OPEN_PROFILE_NAME"; exit 130' INT TERM
  # EXIT: catch the "boring crashed unexpectedly" path so we don't orphan the
  # collector subshell. Idempotent with the INT/TERM teardown above.
  trap '_cmd_open_stop_audit_collector "${BORING_OPEN_PROFILE_NAME:-}"' EXIT

  # Resolve !secret URIs into a --remote-env arg list. Resolved secret values
  # never touch disk: compose.sh skips secret-kind env, and these args are
  # passed straight to `devcontainer up` (which injects via the runtime env).
  # Output written to the global BORING_REMOTE_ENV_ARGS (see top of file).
  _cmd_open_resolve_secrets "$profile_json"

  # Stamp the profile name + host username into the container env so the
  # audit-emit shim can fill the JSON envelope's profile/user fields. These
  # are not secrets but they ride the same --remote-env channel so they
  # don't end up baked into compose YAML on disk.
  BORING_REMOTE_ENV_ARGS+=(--remote-env "BORING_PROFILE_NAME=$name")
  BORING_REMOTE_ENV_ARGS+=(--remote-env "BORING_HOST_USER=${USER:-unknown}")

  # Start the audit collector BEFORE compose generation so its FIFO is in place
  # by the time docker bind-mounts it into the container. compose.sh references
  # the FIFO path; the FIFO needs to be a real FIFO (not a regular file Docker
  # auto-creates from a missing mount source) at `devcontainer up` time.
  _cmd_open_start_audit_collector "$profile_json"

  log_step "Generating .devcontainer/{docker-compose.yml,devcontainer.json}"
  # --project-name pins the compose project so sidecar container names are
  # predictable (e.g., <profile>-postgres-1). cmd_run already did this; cmd_open
  # adopts it here so ARD-0012 dbx restores can target sidecars by name
  # without scraping `docker ps` heuristics.
  compose_generate "$profile_json" "$repo" --project-name "$name"
  log_success ".devcontainer/ written"

  # ARD-0009: emit the guardrails runtime artifacts (pre-push hook, command
  # wrappers, merged Claude settings) into .devcontainer/boring-runtime/.
  # Bind-mounted RO into the container by compose_generate's volumes block.
  log_step "Generating .devcontainer/boring-runtime/ (ARD-0009 guardrails)"
  _compose_emit_guardrails_runtime "$profile_json" "$repo"
  log_success "boring-runtime/ written"

  # ARD-0026 + ARD-0028: harness-agnostic codegen — CLAUDE.md, AGENTS.md, and
  # the OpenCode permission config — into .boring/codegen/. Same trust-anchor
  # pattern (host-writes, container-reads-RO via the workspace bind-mount; the
  # AGENTS.md additionally rebinds at /home/dev/.config/opencode/AGENTS.md via
  # compose.sh's volumes block).
  log_step "Generating .boring/codegen/ (ARD-0026 + ARD-0028)"
  guardrails_emit_codegen_dir "$profile_json" "$repo"
  log_success ".boring/codegen/ written"

  # ARD-0011: set BORING_EGRESS_MODE so the in-container install-egress
  # entrypoint picks it up. Only meaningful when egress.allow is non-empty
  # (in which case compose.sh wired NET_ADMIN + the env var into the dev
  # service). Extends the SIGINT trap to also emit the --learn-mode diff
  # before the audit collector teardown fires.
  if [[ "$learn_mode" -eq 1 ]]; then
    if egress_enabled "$profile_json"; then
      export BORING_EGRESS_MODE=learn
      log_info "egress: --learn-mode active (LOG-only, no REJECT)"
      BORING_OPEN_LEARN_REPO="$repo"
      trap '_cmd_open_emit_learn_diff "$BORING_OPEN_LEARN_REPO"; _cmd_open_stop_audit_collector "$BORING_OPEN_PROFILE_NAME"; exit 130' INT TERM
    else
      log_warn "egress: --learn-mode requested but profile has no egress.allow — nothing to learn"
    fi
  fi

  log_step "Bringing dev container up (devcontainer up)"
  # ${arr[@]+"${arr[@]}"} (unwrapped) is the bash-3.2-safe idiom that expands
  # to nothing on an empty array under `set -u`. The fully-wrapped variant
  # "${arr[@]+...}" would inject a single empty-string arg, breaking the CLI.
  devcontainer_up --workspace-folder "$repo" ${BORING_REMOTE_ENV_ARGS[@]+"${BORING_REMOTE_ENV_ARGS[@]}"}

  # ARD-0012: fire any restore: entries against the now-running sidecars.
  # Order matters — restore THEN setup hooks, so migrate/bootstrap_data run
  # against the prod-shaped data rather than an empty schema. No-op if no
  # restore: entries declared.
  _cmd_open_run_restores "$profile_json" "$name"

  _cmd_open_verify_setup "$profile_json" "$repo"

  # The collector keeps running across the container's lifetime; the user
  # signals shutdown with Ctrl-C, which the trap catches. Print a hint so the
  # user knows the foreground process they just attached to has audit duty.
  log_success "Ready. Attach your editor, or open a shell with:"
  log_info "  devcontainer exec --workspace-folder \"$repo\" -- bash"
  log_info "Audit collector running (pid $(cat "$(audit_pid_file "$name")" 2>/dev/null || echo '?')). Ctrl-C to tear down."
  if [[ "$learn_mode" -eq 1 ]] && egress_enabled "$profile_json"; then
    log_info "egress --learn-mode: use the container, then Ctrl-C to print the proposed allowlist diff."
  fi

  # Hold the foreground until the user signals shutdown. Without this wait,
  # the script would exit immediately, EXIT-trap-tearing-down the collector
  # while the container is still up. devcontainer up returns once the
  # container is healthy; we then wait on the collector pid. SIGINT fires the
  # combined trap above (audit teardown + optional --learn-mode diff).
  _cmd_open_wait_for_shutdown "$name"
}

# _cmd_open_start_audit_collector <profile-json>
# Routes the profile's audit.prompts setting into the collector so it knows
# which prompt log file to write to. Always non-fatal: a failed collector
# start shouldn't block the container from coming up — the user will see
# missing audit data and `boring doctor` (TODO) will flag it.
_cmd_open_start_audit_collector() {
  local profile_json="$1"
  local profile visibility
  profile="$(jq -r '.name' <<<"$profile_json")"
  visibility="$(jq -r '.audit.prompts // "per_user"' <<<"$profile_json")"

  log_step "Starting audit collector (profile=$profile, prompts=$visibility)"
  if audit_collector_start "$profile" "$visibility"; then
    log_success "audit collector live; FIFO at $(audit_fifo_path "$profile")"
  else
    log_warn "audit collector failed to start (events will not be captured this session)"
  fi
}

# _cmd_open_stop_audit_collector <profile-name>
# Invoked from the SIGINT/SIGTERM trap and from the foreground waiter. Tears
# down the collector + FIFO. Idempotent.
_cmd_open_stop_audit_collector() {
  local profile="${1:-}"
  [[ -z "$profile" ]] && return 0
  log_step "Stopping audit collector for profile $profile"
  audit_collector_stop "$profile" || true
}

# _cmd_open_wait_for_shutdown <profile-name>
# Blocks the foreground on the collector PID. The trap on INT/TERM does the
# teardown; this wait just keeps the script alive so the trap can fire.
_cmd_open_wait_for_shutdown() {
  local profile="$1"
  local pid pidfile
  pidfile="$(audit_pid_file "$profile")"
  pid="$(cat "$pidfile" 2>/dev/null || echo '')"
  [[ -z "$pid" ]] && return 0
  # `wait` only works on direct children; fall back to a polling loop because
  # the collector was spawned via subshell `&` and may not be in the same
  # job table as our current shell on every bash version.
  while kill -0 "$pid" 2>/dev/null; do
    sleep 1
  done
}

# _cmd_open_resolve_secrets <profile-json>
# Walks env entries; for each secret URI, calls secret_resolve and appends a
# "--remote-env KEY=VALUE" pair to the global BORING_REMOTE_ENV_ARGS. Failure
# on any secret aborts the open with a clear message (the container is NOT
# brought up if a required secret can't be resolved — die exits the main
# shell, since this function runs in the same process).
_cmd_open_resolve_secrets() {
  local profile_json="$1"
  BORING_REMOTE_ENV_ARGS=()

  local entries
  entries="$(jq -r '
    .env // {} | to_entries
    | map(select(.value.kind == "secret"))
    | map("\(.key)\t\(.value.uri)") | .[]
  ' <<<"$profile_json")"

  [[ -z "$entries" ]] && return 0

  log_step "Resolving secret URIs (ARD-0002 resolver)"
  local count=0
  while IFS=$'\t' read -r key uri; do
    log_info "  $key ← $uri"
    local value
    if ! value="$(secret_resolve "$uri" 2>&1)"; then
      die "Failed to resolve secret for env.$key (URI: $uri): $value"
    fi
    BORING_REMOTE_ENV_ARGS+=(--remote-env "$key=$value")
    # POSIX-portable counter increment (the (( c++ )) form returns 1 when c
    # was 0, which `set -e` would treat as failure).
    count=$((count + 1))
  done <<<"$entries"
  log_success "Resolved $count secret(s)"
}

# _cmd_open_verify_setup <profile-json> <workspace>
# After devcontainer up, checks that the setup-complete marker file exists.
# If not, re-runs the setup commands via devcontainer exec. No-op when the
# profile declares no setup: list. (ARD-0007 §5 belt-and-suspenders.)
_cmd_open_verify_setup() {
  local profile_json="$1" workspace="$2"

  local has_setup
  has_setup="$(jq -r '((.setup // []) | length) > 0' <<<"$profile_json")"
  [[ "$has_setup" == "true" ]] || return 0

  log_step "Verifying setup completion marker"
  if devcontainer_exec --workspace-folder "$workspace" \
       -- test -f /var/lib/boring/setup-complete >/dev/null 2>&1; then
    log_success "setup-complete marker present"
    return 0
  fi

  log_warn "setup marker missing — postCreateCommand may have failed; re-running setup"
  # Single source for the setup shell-string; same chain compose.sh emitted
  # into postCreateCommand. Keeps the two paths in lockstep.
  local setup_cmd
  setup_cmd="$(profile_setup_command "$profile_json")"

  devcontainer_exec --workspace-folder "$workspace" \
    -- bash -lc "$setup_cmd" \
    || die "setup re-run failed; inspect the container with: devcontainer exec --workspace-folder \"$workspace\" -- bash"

  log_success "setup completed (after re-run)"
}

# _cmd_open_run_restores <profile-json> <profile-name>
# ARD-0012 §2: walk the resolved restore: list; for each entry, run
# `dbx restore <source> --transform=<path> --into <container>` against the
# compose-managed sidecar container. Honors `when:` semantics:
#   - first_up: only fire if the marker is absent (idempotent across opens)
#   - every_up: always fire (use sparingly — bypasses idempotency)
#   - manual:   never fire here (user invokes `boring restore --refresh`)
# Marker path: ~/.local/share/boring/restore-state/<profile>/<idx>-<target>.complete
# Errors abort the open — a failed restore is worse than no restore (setup
# hooks downstream would run against half-populated data).
_cmd_open_run_restores() {
  local profile_json="$1" profile_name="$2"

  local count
  count="$(jq -r '(.restore // []) | length' <<<"$profile_json")"
  [[ "$count" -eq 0 ]] && return 0

  require_cmd dbx "Install dbx: curl -fsSL https://raw.githubusercontent.com/steig/dbx/main/install.sh | bash"

  local state_dir="$DATA_DIR/restore-state/$profile_name"
  mkdir -p "$state_dir"

  log_step "Running restore: entries (ARD-0012)"
  local idx
  for (( idx=0; idx<count; idx++ )); do
    local source target transform when marker
    source="$(jq -r ".restore[$idx].source" <<<"$profile_json")"
    target="$(jq -r ".restore[$idx].target" <<<"$profile_json")"
    transform="$(jq -r ".restore[$idx].transform // empty" <<<"$profile_json")"
    when="$(jq -r ".restore[$idx].when // \"first_up\"" <<<"$profile_json")"
    marker="$state_dir/$idx-$target.complete"

    case "$when" in
      manual)
        log_info "  [$idx] $source → $target (when: manual — skipping; run boring restore --refresh)"
        continue ;;
      first_up)
        if [[ -f "$marker" ]]; then
          log_info "  [$idx] $source → $target (when: first_up, marker present — skipping)"
          continue
        fi ;;
      every_up) ;;  # always run
    esac

    # Compose container naming: <project>-<service>-<index>. We pinned project
    # to the profile name via --project-name; index is 1 for a single-replica
    # service. Resolves to e.g. "content-infra-postgres-1".
    local container="${profile_name}-${target}-1"
    log_info "  [$idx] $source → $container${transform:+ (transform: $transform)}"

    local dbx_args=("restore" "$source" "--into" "$container")
    [[ -n "$transform" ]] && dbx_args+=("--transform=$transform")
    if ! dbx "${dbx_args[@]}"; then
      die "restore[$idx] failed (source: $source, target: $container). Container left running; fix the source or transform and re-run with: boring restore $profile_name --refresh"
    fi

    : > "$marker"
  done
  log_success "All restore: entries complete"
}

# _cmd_open_emit_learn_diff <repo>
# Triggered by the --learn-mode SIGINT trap (combined with the audit-collector
# teardown). ARD-0015: reads the egress-logger sidecar's ulogd.json directly
# from the host-side bind-mount (no `devcontainer exec` round-trip needed —
# the file is on the host filesystem). Runs the parser and prints the
# proposed egress.allow diff for the user to paste into the profile.
# Best-effort: if the log file is missing (sidecar never started, learn mode
# wasn't actually active, etc.), log a warning.
_cmd_open_emit_learn_diff() {
  local repo="$1"
  log_step "egress: collecting --learn-mode attempts"
  local ulogd_json="$repo/.devcontainer/boring-runtime/egress-log/ulogd.json"
  if [[ ! -r "$ulogd_json" ]]; then
    log_warn "egress: no ulogd.json at $ulogd_json (egress-logger sidecar may not have started, or --learn-mode was not active for this session)"
    return 0
  fi
  local profile_json
  profile_json="$(profile_load "$repo")"
  egress_propose_allowlist_diff "$profile_json" "$ulogd_json"
}

# ============================================================================
# cmd_run — headless one-shot Claude invocation in a profile-scoped sandbox
# Per ARD-0013. Fresh container per invocation, identical secret code path to
# cmd_open, same trust-anchor / guardrails posture (everything baked into the
# image applies — there is no headless-only relaxation).
# ============================================================================

# _cmd_run_compose_project_name <profile-name> -> echoes "boring-run-<profile>-<suffix>"
# 8-char hex suffix from /dev/urandom keeps invocations from colliding when
# multiple `boring run` jobs target the same profile concurrently and means
# nothing about it leaks into the user-facing namespace.
_cmd_run_compose_project_name() {
  local profile_name="$1"
  local suffix
  suffix="$(head -c 4 /dev/urandom | od -An -tx1 | tr -d ' \n')"
  echo "boring-run-${profile_name}-${suffix}"
}

# _cmd_run_resolve_secrets <profile-json> -> populates the global
# _CMD_RUN_REMOTE_ENV_ARGS array with `--remote-env KEY=VALUE` pairs for each
# secret URI in env. Resolution happens in memory; resolved values are NEVER
# written to disk. Fails fast on any unresolvable URI BEFORE any container is
# brought up. Per ARD-0013 §3, this is the same code path cmd_open will use;
# the shared name lives here pending the cmd_open hardening slice (ARD-0009/10).
declare -a _CMD_RUN_REMOTE_ENV_ARGS=()
_cmd_run_resolve_secrets() {
  local profile_json="$1"
  _CMD_RUN_REMOTE_ENV_ARGS=()

  # Iterate every env entry classified as kind=secret by profile_normalize.
  # jq -r emits one tab-delimited "KEY\tURI" line per secret; safe because
  # env names are slug-shaped and secret URIs don't contain tabs.
  local secret_lines
  secret_lines="$(jq -r '
    .env | to_entries
    | map(select(.value.kind == "secret"))
    | .[]
    | "\(.key)\t\(.value.uri)"
  ' <<<"$profile_json")"

  [[ -z "$secret_lines" ]] && return 0

  local key uri value
  while IFS=$'\t' read -r key uri; do
    [[ -z "$key" ]] && continue
    log_info "Resolving secret: $key (uri: $uri)"
    if ! value="$(secret_resolve "$uri")"; then
      die "boring run: failed to resolve secret for env.$key (uri: $uri). Pre-flight aborted; no container was started."
    fi
    [[ -z "$value" ]] && die "boring run: secret_resolve returned empty value for env.$key (uri: $uri)."
    # --remote-env is the devcontainer CLI flag that injects KEY=VAL into the
    # container env at exec time without persisting to docker-compose.yml.
    _CMD_RUN_REMOTE_ENV_ARGS+=("--remote-env" "${key}=${value}")
  done <<<"$secret_lines"
}

# _cmd_run_teardown <project-name> <workspace>
# Tear down the one-shot compose stack. `-v` removes named volumes so the next
# `boring run` against the same profile starts from a clean slate. Safe to call
# multiple times (idempotent at the docker layer), but we reset the trap on
# entry so a SIGINT-followed-by-EXIT cascade doesn't run teardown twice and
# spam the log.
_cmd_run_teardown() {
  trap - EXIT INT TERM
  local project_name="$1"
  local workspace="$2"
  [[ -z "$project_name" ]] && return 0
  [[ -d "$workspace/.devcontainer" ]] || return 0
  log_step "Tearing down container (project: $project_name)"
  (
    cd "$workspace"
    docker compose \
      --project-name "$project_name" \
      --project-directory .devcontainer \
      -f .devcontainer/docker-compose.yml \
      down -v --remove-orphans 2>/dev/null
  ) || log_warn "boring run: teardown encountered an error (project $project_name); may need manual 'docker compose --project-name $project_name down -v'."
}

# _cmd_run_print_help — usage for `boring run`
_cmd_run_print_help() {
  cat <<EOF
boring run — headless one-shot Claude invocation (ARD-0013)

USAGE
  boring run "<claude-prompt>" --profile <name> [--repo <path>]

ARGUMENTS
  <claude-prompt>     Prompt passed to Claude Code's headless mode (claude -p).
                      Must be a single positional argument; quote multi-word.

OPTIONS
  --profile <name>    Required. Slug-shaped name matching the loaded profile's
                      \`name:\` field. Used to scope the temporary compose project.
  --repo <path>       Optional. Path to the boring-enabled repo containing
                      \`.boring/profile.yaml\`. Defaults to the current directory.
  -h, --help          Print this help and exit.

BEHAVIOR
  1. Loads .boring/profile.yaml from --repo (or .).
  2. Resolves every secret:// URI in env IN MEMORY. Fails fast on any error
     before any container is started.
  3. Generates a one-shot compose stack with a unique project name
     (boring-run-<profile>-<random-suffix>).
  4. Brings the container up via \`devcontainer up --remove-existing-container\`,
     injecting resolved secrets as \`--remote-env KEY=VAL\`.
  5. Invokes Claude headlessly inside the container with the prompt.
  6. Streams Claude stdout to this terminal. Tears down on exit (including
     SIGINT / SIGTERM). \`-v\` is passed to \`docker compose down\` so named
     volumes are removed — fresh state per invocation, by design.
  7. Exits with Claude's exit code.

EOF
}

cmd_run() {
  local prompt=""
  local profile_arg=""
  local repo="."

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)    _cmd_run_print_help; return 0 ;;
      --profile)
        [[ $# -ge 2 ]] || die "boring run: --profile requires a value"
        profile_arg="$2"; shift 2 ;;
      --repo)
        [[ $# -ge 2 ]] || die "boring run: --repo requires a value"
        repo="$2"; shift 2 ;;
      --)           shift; prompt="${1:-$prompt}"; shift || true ;;
      -*)           die "boring run: unknown flag: $1 (try: boring run --help)" ;;
      *)
        if [[ -z "$prompt" ]]; then
          prompt="$1"; shift
        else
          die "boring run: unexpected positional argument: $1 (the prompt must be a single quoted string)"
        fi
        ;;
    esac
  done

  [[ -z "$prompt" ]] && { _cmd_run_print_help >&2; die "boring run: missing prompt argument"; }
  [[ -z "$profile_arg" ]] && die "boring run: --profile is required (try: boring run --help)"
  [[ "$profile_arg" =~ ^[a-z0-9-]+$ ]] || die "boring run: --profile must be slug-shaped [a-z0-9-]+ (got: $profile_arg)"
  [[ -d "$repo" ]] || die "boring run: --repo not a directory: $repo"
  repo="$(cd "$repo" && pwd)"

  log_step "Loading profile from $repo/.boring/profile.yaml"
  local profile_json
  profile_json="$(profile_load "$repo")"

  local profile_name
  profile_name="$(jq -r '.name' <<<"$profile_json")"
  if [[ "$profile_name" != "$profile_arg" ]]; then
    die "boring run: --profile mismatch — profile.yaml declares name '$profile_name' but --profile was '$profile_arg'"
  fi
  log_info "Profile: $profile_name"

  log_step "Pre-flighting secret URIs (in memory; no disk write)"
  _cmd_run_resolve_secrets "$profile_json"
  # Each secret pushes two array elements (--remote-env + KEY=VAL), so divide
  # the array length by 2 for the user-visible count.
  log_success "Secrets resolved: $(( ${#_CMD_RUN_REMOTE_ENV_ARGS[@]} / 2 )) entries (--remote-env pairs prepared)"

  local project_name
  project_name="$(_cmd_run_compose_project_name "$profile_name")"
  log_info "Compose project: $project_name"

  # Register teardown trap BEFORE we bring anything up. Covers normal exit,
  # SIGINT (Ctrl-C), SIGTERM, and ERR (set -e induced failures). We can't trap
  # SIGKILL — detection of orphans on that path is via `docker ps` filtering on
  # the unique project name (`boring-run-*`).
  trap '_cmd_run_teardown "$project_name" "$repo"' EXIT INT TERM

  log_step "Generating .devcontainer/{docker-compose.yml,devcontainer.json} (project: $project_name)"
  compose_generate "$profile_json" "$repo" --project-name "$project_name"
  log_success ".devcontainer/ written"

  log_step "Bringing dev container up (devcontainer up --remove-existing-container)"
  # The `${arr[@]+"${arr[@]}"}` pattern is the canonical defense against the
  # bash 3.2 "unbound variable" failure on empty arrays under `set -u`. If the
  # profile has no secrets, _CMD_RUN_REMOTE_ENV_ARGS is empty and we expand to
  # nothing; if it has secrets, we expand to the pairs.
  devcontainer_up \
    --workspace-folder "$repo" \
    --remove-existing-container \
    ${_CMD_RUN_REMOTE_ENV_ARGS[@]+"${_CMD_RUN_REMOTE_ENV_ARGS[@]}"}

  log_step "Running Claude headlessly inside container"
  # Claude Code's non-interactive mode: `claude -p "<prompt>"` (per ARD-0013 §2
  # and the Claude Code CLI docs). Output streams to this terminal as Claude
  # produces it; exit code propagates to `boring`.
  local claude_exit=0
  devcontainer_exec \
    --workspace-folder "$repo" \
    -- claude -p "$prompt" || claude_exit=$?

  log_info "Claude exited with code: $claude_exit"
  # Teardown runs via the EXIT trap; exit with Claude's code to preserve
  # CI-friendly exit semantics.
  exit "$claude_exit"
}

# cmd_restore [<repo-path>] [--refresh]
# ARD-0012: manual surface over the restore: pipeline. By default, walks
# the profile's restore list and re-runs any entries whose marker is missing
# (idempotent). With --refresh, clears all markers first so every entry
# re-runs regardless of state. Use when:
#   - a sanitize script changed (re-run with new transform)
#   - a fresh snapshot lands upstream (re-pull from dbx)
#   - manual-when entries need to fire (they never auto-run in cmd_open)
# The dev containers must be running — restore targets are compose-managed
# sidecars resolved by name; if they aren't up, dbx --into fails clearly.
cmd_restore() {
  local repo="" refresh=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --refresh) refresh=1; shift ;;
      -*) die "boring restore: unknown flag $1" ;;
      *) [[ -z "$repo" ]] && repo="$1" || die "boring restore: extra argument $1"; shift ;;
    esac
  done
  repo="${repo:-.}"
  [[ -d "$repo" ]] || die "boring restore: not a directory: $repo"
  repo="$(cd "$repo" && pwd)"

  local profile_json name
  profile_json="$(profile_load "$repo")"
  name="$(jq -r '.name' <<<"$profile_json")"

  if [[ "$refresh" -eq 1 ]]; then
    local state_dir="$DATA_DIR/restore-state/$name"
    log_step "--refresh: clearing restore markers for $name"
    rm -f "$state_dir"/*.complete 2>/dev/null || true
  fi

  # _cmd_open_run_restores enforces when: semantics and handles markers.
  # --refresh just clears markers first; the function does the work.
  # For manual: entries, --refresh is the only path that fires them.
  if [[ "$refresh" -eq 1 ]]; then
    # Temporarily promote manual → every_up so --refresh actually re-runs
    # them. Without this, manual entries would still skip even after
    # marker clear (since the case statement skips on when: manual).
    profile_json="$(jq '(.restore // []) |= map(if .when == "manual" then .when = "every_up" else . end)' <<<"$profile_json")"
  fi

  _cmd_open_run_restores "$profile_json" "$name"
}

# cmd_audit security|prompts <profile>
# Read-only surface over the JSONL audit logs (ARD-0010 §5). `security` always
# reads from the shared profile-wide file; `prompts` honors the profile's
# audit.prompts setting (per_user reads <USER>/<profile>/prompts.jsonl, shared
# reads _shared/<profile>/prompts.jsonl). Reading does not require the
# container to be up — a PM can scroll yesterday's session.
cmd_audit() {
  local sub="${1:-}"; shift || true
  local profile="${1:-}"; shift || true
  case "$sub" in
    security)
      [[ -n "$profile" ]] || die "boring audit security: missing <profile>"
      audit_cat_security "$profile" ;;
    prompts)
      [[ -n "$profile" ]] || die "boring audit prompts: missing <profile>"
      # Resolve audit.prompts from the profile if we can find the repo; default
      # to per_user otherwise. The repo isn't required (the logs live in
      # $DATA_DIR keyed by profile name), but knowing visibility is.
      local visibility="per_user"
      if [[ -f ".boring/profile.yaml" ]]; then
        local pjson
        pjson="$(profile_load "$(pwd)" 2>/dev/null || echo '')"
        [[ -n "$pjson" ]] && visibility="$(jq -r '.audit.prompts // "per_user"' <<<"$pjson")"
      fi
      audit_cat_prompts "$profile" "$visibility" ;;
    *)
      log_error "boring audit: usage: boring audit {security|prompts} <profile>"
      exit 1 ;;
  esac
}

cmd_doctor() {
  doctor_run "$@"
}

# ============================================================================
# cmd_wip — WIP-branch lifecycle (ARD-0022 §3)
# Designed to be invoked both directly by engineers and shelled out from the
# in-container boring-ui backend per turn. Subcommands: start, commit, discard.
# ============================================================================

_cmd_wip_print_help() {
  cat <<EOF
boring wip — WIP-branch lifecycle (ARD-0022 §3)

USAGE
  boring wip start   <profile|.> [--marketer <name>] [--ts <ts>] [--base <branch>]
  boring wip commit  <profile|.> --prompt <text>
  boring wip discard <profile|.> [--force]

SUBCOMMANDS
  start    Create (or check out) a WIP branch for the session.
  commit   Stage all changes and commit the current turn (AI-summarized msg).
  discard  Delete the current WIP branch (refuses if unsaved commits unless --force).

OPTIONS
  --marketer <name>  Marketer username (default: \$USER).
  --ts <ts>          Session-resumed-at timestamp (default: now, format: YYYYMMDDHHMMSS).
  --base <branch>    Base branch for the WIP (default: save.target_branch or main).
  --prompt <text>    Prompt text used to derive the commit message subject.
  --force            For 'discard': delete even if commits are unsaved.

EOF
}

# _cmd_wip_resolve_repo_and_profile <arg>
# Mirrors cmd_save: accepts "." (cwd repo) or a path; returns repo + profile_json
# via two globals (bash 3.2 has no map returns).
_CMD_WIP_REPO=""
_CMD_WIP_PROFILE_JSON=""
_cmd_wip_resolve_repo_and_profile() {
  local target="${1:-.}"
  [[ -d "$target" ]] || die "boring wip: not a directory: $target"
  _CMD_WIP_REPO="$(cd "$target" && pwd)"
  _CMD_WIP_PROFILE_JSON="$(profile_load "$_CMD_WIP_REPO")"
}

cmd_wip() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    -h|--help|"") _cmd_wip_print_help; [[ -z "$sub" ]] && return 1 || return 0 ;;
  esac

  local target=""
  local marketer="${USER:-marketer}"
  local ts=""
  local base=""
  local prompt=""
  local force=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --marketer) [[ $# -ge 2 ]] || die "boring wip: --marketer requires a value"
                  marketer="$2"; shift 2 ;;
      --ts)       [[ $# -ge 2 ]] || die "boring wip: --ts requires a value"
                  ts="$2"; shift 2 ;;
      --base)     [[ $# -ge 2 ]] || die "boring wip: --base requires a value"
                  base="$2"; shift 2 ;;
      --prompt)   [[ $# -ge 2 ]] || die "boring wip: --prompt requires a value"
                  prompt="$2"; shift 2 ;;
      --force)    force="--force"; shift ;;
      -h|--help)  _cmd_wip_print_help; return 0 ;;
      -*)         die "boring wip: unknown flag $1" ;;
      *)          [[ -z "$target" ]] && target="$1" || die "boring wip: extra argument $1"
                  shift ;;
    esac
  done

  target="${target:-.}"
  _cmd_wip_resolve_repo_and_profile "$target"

  case "$sub" in
    start)
      [[ -z "$ts" ]] && ts="$(date +%Y%m%d%H%M%S)"
      [[ -z "$base" ]] && base="$(jq -r '.save.target_branch // "main"' <<<"$_CMD_WIP_PROFILE_JSON")"
      local branch
      branch="$(saver_wip_branch_name "$marketer" "$ts")"
      saver_create_wip_branch "$_CMD_WIP_REPO" "$branch" "$base"
      log_success "WIP branch ready: $branch"
      ;;
    commit)
      [[ -z "$prompt" ]] && die "boring wip commit: --prompt is required"
      local msg
      msg="$(saver_summarize_turn "$_CMD_WIP_REPO" "$prompt")"
      saver_commit_turn "$_CMD_WIP_REPO" "$msg"
      ;;
    discard)
      local current
      current="$(git -C "$_CMD_WIP_REPO" rev-parse --abbrev-ref HEAD)"
      if [[ "$current" != boring/wip/* ]]; then
        die "boring wip discard: current branch ($current) is not a WIP branch (expected boring/wip/...)"
      fi
      saver_discard_wip "$_CMD_WIP_REPO" "$current" "$force"
      ;;
    *)
      log_error "boring wip: unknown subcommand: $sub"
      _cmd_wip_print_help >&2
      exit 1
      ;;
  esac
}

# ============================================================================
# cmd_save — promote the WIP branch to a named branch + PR (ARD-0022 §7)
# ============================================================================

_cmd_save_print_help() {
  cat <<EOF
boring save — promote the current WIP branch to a PR (ARD-0022 §7)

USAGE
  boring save <profile|.> [--message <text>] [--draft|--ready] [--target <branch>]

ARGUMENTS
  <profile|.>        Path to a boring-enabled repo (use "." for the cwd).

OPTIONS
  --message <text>   Title override (default: AI-summarized from cumulative diff).
  --draft            Open the PR as a draft (override profile save.draft_by_default).
  --ready            Open the PR ready for review (override profile save.draft_by_default).
  --target <branch>  Target branch override (default: profile save.target_branch).
  -h, --help         Print this help.

BEHAVIOR
  1. Reads the profile's save: block from .boring/profile.yaml.
  2. Branches the current WIP branch into <branch_prefix><slug>-<date>-<sha>.
  3. Pushes to origin and opens a PR via 'gh pr create'.
  4. On failure (gh not authed, network down, push rejected), leaves the WIP
     branch intact and prints an actionable error.
EOF
}

cmd_save() {
  local target=""
  local -a saver_flags
  saver_flags=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        _cmd_save_print_help; return 0 ;;
      --message|--target)
        [[ $# -ge 2 ]] || die "boring save: $1 requires a value"
        saver_flags+=("$1" "$2"); shift 2 ;;
      --draft|--ready)
        saver_flags+=("$1"); shift ;;
      -*)
        die "boring save: unknown flag $1" ;;
      *)
        [[ -z "$target" ]] && target="$1" || die "boring save: extra argument $1"
        shift ;;
    esac
  done

  target="${target:-.}"
  [[ -d "$target" ]] || die "boring save: not a directory: $target"
  local repo
  repo="$(cd "$target" && pwd)"

  local profile_json
  profile_json="$(profile_load "$repo")"

  # `${arr[@]+"${arr[@]}"}` is the bash-3.2-safe empty-array splat (same
  # pattern used by cmd_open / cmd_run for --remote-env args).
  saver_save "$repo" "$profile_json" ${saver_flags[@]+"${saver_flags[@]}"}
}

# cmd_proxy — thin dispatcher into the boring-proxy Go binary (ARD-0021).
# v0: built by `make -C tools/boring-proxy build`; we look next to the CLI.
cmd_proxy() {
  local proxy_bin="$SCRIPT_DIR/tools/boring-proxy/boring-proxy"
  if [[ ! -x "$proxy_bin" ]]; then
    log_error "boring-proxy binary not found at: $proxy_bin"
    log_info "Build it first: make -C tools/boring-proxy build"
    log_info "(requires Go 1.22+; see tools/boring-proxy/ for source)"
    exit 1
  fi
  exec "$proxy_bin" "$@"
}

cmd_version() {
  echo "boring $VERSION"
}

cmd_help() {
  cat <<EOF
boring $VERSION — dev container launcher for wrapped apps

USAGE
  boring open [--learn-mode] <path>          Open a boring-enabled repo
  boring run "<prompt>" --profile <name>     Headless one-shot Claude (ARD-0013)
  boring restore [<path>] [--refresh]        Run/re-run restore: entries (ARD-0012)
  boring audit security <profile>            Read profile-shared security events (ARD-0010)
  boring audit prompts  <profile>            Read prompt events (per-user by default)
  boring proxy <subcommand>                  Host-side reverse proxy (ARD-0021, v1.x)
                                             Subcommands: install, uninstall, serve,
                                             status, rotate-token
  boring wip {start|commit|discard} <path>   WIP-branch lifecycle (ARD-0022 §3)
  boring save <path> [--message --draft ...] Promote WIP branch to PR (ARD-0022 §7)
  boring doctor                              Diagnose environment
  boring version                             Print version
  boring help                                Print this help

FLAGS
  --learn-mode   Per ARD-0011, install iptables LOG-only egress rules and
                 propose an allowlist diff on Ctrl-C. No-op for profiles
                 without egress.allow.

A boring-enabled repo contains a .boring/profile.yaml describing the dev
environment. boring composes existing tools (dbx, devcontainer CLI, docker)
rather than reimplementing them; see docs/ards/ for the design record.

DOCS
  https://github.com/steig/boring
EOF
}

# ============================================================================
# Main dispatch
# ============================================================================

main() {
  local subcommand="${1:-help}"
  shift || true

  case "$subcommand" in
    open)               cmd_open    "$@" ;;
    run)                cmd_run     "$@" ;;
    restore)            cmd_restore "$@" ;;
    audit)              cmd_audit   "$@" ;;
    proxy)              cmd_proxy   "$@" ;;
    wip)                cmd_wip     "$@" ;;
    save)               cmd_save    "$@" ;;
    doctor)             cmd_doctor  "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help)     cmd_help ;;
    *)
      log_error "Unknown command: $subcommand"
      echo >&2
      cmd_help >&2
      exit 1
      ;;
  esac
}

main "$@"
