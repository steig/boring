# ============================================================================
# cmd_secret — provision/read/remove a secret in the OS keyring (ARD-0032).
# One-time, host-side helper so `secret://keychain:<service>/<account>` resolves
# with zero per-use auth (e.g. an engineer drops a Theme Access token onto a
# non-engineer's machine at onboarding; `boring open` injects it thereafter).
# boring owns no store — this writes the OS keyring (macOS Keychain / libsecret),
# the same backend the keychain: scheme reads. The value is read from STDIN,
# keeping it out of shell history (macOS `security -w` does briefly place it in
# the `security` process argv — see lib/secrets.sh; the Linux path pipes stdin).
# ============================================================================
cmd_secret() {
  local action="${1:-}"
  shift || true
  case "$action" in
    set) secret_set "${1:-}" ;;
    get) secret_get "${1:-}" ;;
    rm)  secret_rm  "${1:-}" ;;
    ""|-h|--help|help)
      cat <<'EOF'
boring secret — provision a secret into the OS keyring for secret://keychain: resolution

USAGE
  printf '%s' "<value>" | boring secret set <service>/<account>
  boring secret get <service>/<account>
  boring secret rm  <service>/<account>

The value is read from stdin (kept out of your shell history). The profile
references it as secret://keychain:<service>/<account>, which boring injects
into the container at `boring open` with zero per-use auth.

EXAMPLE (one-time, at onboarding)
  printf '%s' "$THEME_TOKEN" | boring secret set lamps-shop-theme/THEME_TOKEN
EOF
      ;;
    *)
      die "boring secret: unknown action '$action' (use: set | get | rm)"
      ;;
  esac
}

