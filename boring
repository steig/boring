#!/usr/bin/env bash
#
# boring — dev container launcher for wrapped apps
# https://github.com/steig/boring
#
VERSION="0.1.0-dev"
#
# Usage:
#   boring open <git-url|.>           Clone or attach a boring-enabled repo
#   boring run <profile> --task <t>   Headless task run (v1.x)
#   boring doctor                     Diagnose environment
#   boring version                    Print version
#   boring help                       Print this help
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${BORING_LIB_DIR:-$SCRIPT_DIR/lib}"

# ============================================================================
# Source library modules
# ============================================================================

source "$LIB_DIR/core.sh"
source "$LIB_DIR/secrets.sh"
source "$LIB_DIR/dbx.sh"
source "$LIB_DIR/devcontainer.sh"
source "$LIB_DIR/profile.sh"
source "$LIB_DIR/compose.sh"
source "$LIB_DIR/egress.sh"
source "$LIB_DIR/doctor.sh"

# ============================================================================
# Subcommands
# ============================================================================

cmd_open() {
  # v1 (Shopify-first, ARD-0004): accept a local path; emit
  # .devcontainer/{docker-compose.yml,devcontainer.json} from the profile; bring
  # the container up via devcontainer CLI. URL cloning, secret URI resolution,
  # guardrails codegen are deferred to subsequent slices.
  #
  # Flags:
  #   --learn-mode  Per ARD-0011, install iptables LOG (audit-only) rules
  #                 instead of REJECT. On Ctrl-C, parse the logs and emit a
  #                 proposed egress.allow diff for the user to paste.
  local target=""
  local learn_mode=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --learn-mode) learn_mode=1; shift ;;
      --) shift; break ;;
      -*) die "boring open: unknown flag $1" ;;
      *) [[ -z "$target" ]] && target="$1" || die "boring open: extra argument $1"; shift ;;
    esac
  done
  target="${target:-.}"

  if [[ "$target" =~ ^(git@|https?://) ]]; then
    die "boring open: URL cloning not yet implemented for v1. Clone manually, then run 'boring open <path>'."
  fi

  [[ -d "$target" ]] || die "boring open: not a directory: $target"
  local repo
  repo="$(cd "$target" && pwd)"

  log_step "Loading profile from $repo/.boring/profile.yaml"
  local profile_json
  profile_json="$(profile_load "$repo")"

  local name
  name="$(jq -r '.name' <<<"$profile_json")"
  log_info "Profile: $name"

  log_step "Generating .devcontainer/{docker-compose.yml,devcontainer.json}"
  compose_generate "$profile_json" "$repo"
  log_success ".devcontainer/ written"

  # ARD-0011: set BORING_EGRESS_MODE so the compose file's ${BORING_EGRESS_MODE:-enforce}
  # picks it up. Only meaningful when egress.allow is non-empty (in which case
  # compose.sh has wired NET_ADMIN + the env var into the dev service).
  if [[ "$learn_mode" -eq 1 ]]; then
    if egress_enabled "$profile_json"; then
      export BORING_EGRESS_MODE=learn
      log_info "egress: --learn-mode active (LOG-only, no REJECT)"
      # Install SIGINT trap so Ctrl-C emits a proposed allowlist diff.
      trap "_cmd_open_emit_learn_diff '$repo'" INT TERM
    else
      log_warn "egress: --learn-mode requested but profile has no egress.allow — nothing to learn"
    fi
  fi

  log_step "Bringing dev container up (devcontainer up)"
  devcontainer_up --workspace-folder "$repo"

  log_success "Ready. Attach your editor, or open a shell with:"
  log_info "  devcontainer exec --workspace-folder \"$repo\" -- bash"

  # In --learn-mode we stay attached so the user has a process to Ctrl-C when
  # they're done. The SIGINT trap (installed above) parses the container's
  # kernel log and prints the proposed egress.allow diff. Without this wait,
  # cmd_open would exit immediately and there'd be no opportunity to capture
  # observed attempts.
  if [[ "$learn_mode" -eq 1 ]] && egress_enabled "$profile_json"; then
    log_info "egress: --learn-mode is active. Use the container, then press Ctrl-C to end the session and see the proposed allowlist diff."
    while true; do sleep 86400; done
  fi
}

# Internal: triggered by --learn-mode SIGINT trap. Pulls the container's
# kernel log and runs the iptables LOG parser.
_cmd_open_emit_learn_diff() {
  local repo="$1"
  log_step "egress: collecting --learn-mode attempts"
  local tmp
  tmp="$(mktemp -t boring-learn.XXXXXX)"
  if devcontainer_exec --workspace-folder "$repo" -- dmesg > "$tmp" 2>/dev/null; then
    local profile_json
    profile_json="$(profile_load "$repo")"
    egress_propose_allowlist_diff "$profile_json" "$tmp"
  else
    log_warn "egress: could not collect kernel log from container (container may already be down)"
  fi
  rm -f "$tmp"
}

cmd_run() {
  log_warn "boring run: not yet implemented (v0 skeleton)"
  exit 1
}

cmd_doctor() {
  doctor_run "$@"
}

cmd_version() {
  echo "boring $VERSION"
}

cmd_help() {
  cat <<EOF
boring $VERSION — dev container launcher for wrapped apps

USAGE
  boring open [--learn-mode] <path>  Open a boring-enabled repo
  boring run <profile> --task <t>    Headless task run (v1.x)
  boring doctor                      Diagnose environment
  boring version                     Print version
  boring help                        Print this help

FLAGS
  --learn-mode   Per ARD-0011, install iptables LOG-only egress rules and
                 propose an allowlist diff on Ctrl-C. No-op for profiles
                 without egress.allow.

A boring-enabled repo contains a .boring/profile.yaml describing the dev
environment. boring composes existing tools (dbx, devcontainer CLI, docker)
rather than reimplementing them; see docs/ards/ for the design record.

DOCS
  https://github.com/steig/boring
EOF
}

# ============================================================================
# Main dispatch
# ============================================================================

main() {
  local subcommand="${1:-help}"
  shift || true

  case "$subcommand" in
    open)               cmd_open    "$@" ;;
    run)                cmd_run     "$@" ;;
    doctor)             cmd_doctor  "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help)     cmd_help ;;
    *)
      log_error "Unknown command: $subcommand"
      echo >&2
      cmd_help >&2
      exit 1
      ;;
  esac
}

main "$@"
