# ============================================================================
# cmd_upgrade — pull latest from origin/main (or a pinned tag) at SCRIPT_DIR
# ============================================================================
# boring is installed as a git checkout (install.sh clones it); upgrade is
# just `git fetch + reset --hard` against the install root. Refuses if the
# checkout looks tampered (uncommitted changes) unless --force.

cmd_upgrade() {
  local target="main" force=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tag) target="${2:?--tag requires a value}"; shift 2 ;;
      --force) force=1; shift ;;
      -h|--help)
        cat <<EOF
boring upgrade — pull the latest boring release from GitHub

USAGE
  boring upgrade [--tag <version>] [--force]

OPTIONS
  --tag <version>   Pin to a specific tag (e.g. v0.7.3) instead of latest main.
  --force           Discard uncommitted local changes in the install root.

The install root is wherever boring resolves itself via BASH_SOURCE
($SCRIPT_DIR). Re-run the curl installer if you need to change paths.
EOF
        return 0
        ;;
      *) die "cmd_upgrade: unknown arg: $1" ;;
    esac
  done

  if [[ ! -d "$SCRIPT_DIR/.git" ]]; then
    log_error "boring at $SCRIPT_DIR isn't a git checkout — can't auto-upgrade."
    log_error "Re-run the curl installer:"
    log_error "  curl -fsSL https://raw.githubusercontent.com/steig/boring/main/install.sh | bash"
    exit 1
  fi
  require_cmd git

  # Refuse to clobber local work unless --force.
  if [[ "$force" -eq 0 ]]; then
    local dirty
    dirty="$(git -C "$SCRIPT_DIR" status --porcelain 2>/dev/null | head -1)"
    if [[ -n "$dirty" ]]; then
      log_error "$SCRIPT_DIR has uncommitted changes — refusing to upgrade."
      log_error "Commit/stash them, or pass --force to discard."
      exit 1
    fi
  fi

  local old_version="$VERSION"
  local old_sha
  old_sha="$(git -C "$SCRIPT_DIR" rev-parse --short HEAD)"

  log_step "Fetching from origin"
  git -C "$SCRIPT_DIR" fetch --quiet --tags origin "$target" 2>/dev/null \
    || git -C "$SCRIPT_DIR" fetch --quiet --tags origin
  local new_ref
  if [[ "$target" == "main" ]]; then
    new_ref="FETCH_HEAD"
  else
    new_ref="refs/tags/$target"
    git -C "$SCRIPT_DIR" rev-parse --verify --quiet "$new_ref" >/dev/null \
      || die "tag not found: $target (try: gh release list -R steig/boring)"
  fi

  local new_sha
  new_sha="$(git -C "$SCRIPT_DIR" rev-parse --short "$new_ref")"
  if [[ "$old_sha" == "$new_sha" ]]; then
    log_success "already up to date (boring $old_version, $old_sha)"
    return 0
  fi

  log_step "Updating $old_sha → $new_sha"
  git -C "$SCRIPT_DIR" reset --hard --quiet "$new_ref"

  local new_version
  new_version="$(grep '^VERSION=' "$SCRIPT_DIR/boring" | cut -d'"' -f2)"
  log_success "boring $old_version → $new_version ($new_sha)"
  log_info "  install root → $SCRIPT_DIR"
  log_info "  changelog    → $SCRIPT_DIR/CHANGELOG.md"
  log_info "  releases     → https://github.com/steig/boring/releases"
}

cmd_help() {
  cat <<EOF
boring $VERSION — dev container launcher for wrapped apps

USAGE
  boring open [--learn-mode] [--ui|--no-ui] [--no-dev] <path>
                                             Open a boring-enabled repo
  boring run "<prompt>" --profile <name>     Headless one-shot Claude (ARD-0013)
  boring restore [<path>] [--refresh]        Run/re-run restore: entries (ARD-0012)
  boring audit security <profile>            Read profile-shared security events (ARD-0010)
  boring audit prompts  <profile>            Read prompt events (per-user by default)
  boring proxy <subcommand>                  Host-side reverse proxy (ARD-0021, v1.x)
                                             Subcommands: install, uninstall, serve,
                                             status, rotate-token
  boring secret {set|get|rm} <svc>/<acct>    Provision a secret in the OS keyring so
                                             secret://keychain:<svc>/<acct> resolves with
                                             zero per-use auth (ARD-0032). set reads stdin.
  boring wip {start|commit|discard} <path>   WIP-branch lifecycle (ARD-0022 §3)
  boring save <path> [--message --draft ...] Promote WIP branch to PR (ARD-0022 §7)
  boring ui {status|stop|open} [<slug>]      Manage boring-ui processes (v0.8.0)
  boring doctor                              Diagnose environment
  boring upgrade [--tag <v>] [--force]       Pull the latest boring from GitHub
  boring version                             Print version
  boring help                                Print this help

FLAGS
  --learn-mode   Per ARD-0011, install iptables LOG-only egress rules and
                 propose an allowlist diff on Ctrl-C. No-op for profiles
                 without egress.allow.
  --ui           v0.8.0: after the container is up, bring up the boring-ui
                 web stack (ttyd+claude, proxy, chat backend) and open the
                 browser. Profile may default this via ui.enabled: true.
  --no-ui        v0.8.0: force-disable UI bring-up even if the profile
                 sets ui.enabled: true. Useful for CI / SSH sessions.
  --no-dev       v0.9.0 (ARD-0030): skip dev.command even if profile sets
                 it; drop into bash shell instead. Use when debugging the
                 container or the dev process itself.

A boring-enabled repo contains a .boring/profile.yaml describing the dev
environment. boring composes existing tools (dbx, devcontainer CLI, docker)
rather than reimplementing them; see docs/ards/ for the design record.

DOCS
  https://github.com/steig/boring
EOF
}

# ============================================================================
# Main dispatch
# ============================================================================

main() {
  local subcommand="${1:-help}"
  shift || true

  case "$subcommand" in
    open)               cmd_open    "$@" ;;
    run)                cmd_run     "$@" ;;
    restore)            cmd_restore "$@" ;;
    audit)              cmd_audit   "$@" ;;
    proxy)              cmd_proxy   "$@" ;;
    secret)             cmd_secret  "$@" ;;
    wip)                cmd_wip     "$@" ;;
    save)               cmd_save    "$@" ;;
    ui)                 cmd_ui      "$@" ;;
    doctor)             cmd_doctor  "$@" ;;
    upgrade)            cmd_upgrade "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help)     cmd_help ;;
    *)
      log_error "Unknown command: $subcommand"
      echo >&2
      cmd_help >&2
      exit 1
      ;;
  esac
}

main "$@"
