{
  "permissions": {
    "deny": [
      "Edit(/workspace/.boring/**)",
      "Write(/workspace/.boring/**)",
      "Edit(/workspace/.devcontainer/boring-runtime/**)",
      "Write(/workspace/.devcontainer/boring-runtime/**)",
      "Edit(/home/dev/.claude/settings.json)",
      "Write(/home/dev/.claude/settings.json)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {"hooks": [{"type": "command", "command": "/workspace/.devcontainer/boring-runtime/bin/audit-emit-prompt_issued"}]}
    ],
    "PostToolUse": [
      {"hooks": [{"type": "command", "command": "/workspace/.devcontainer/boring-runtime/bin/audit-emit-tool_used"}]}
    ],
    "Stop": [
      {"hooks": [{"type": "command", "command": "/workspace/.devcontainer/boring-runtime/bin/audit-emit-prompt_completed"}]}
    ]
  }
}
