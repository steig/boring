#!/bin/sh
# install-egress — install iptables OUTPUT rules at container boot, then exec
# the original command as the dev user.
#
# Per ARD-0011, this runs as root (PID 1's first child) before user code.
# It reads:
#   BORING_EGRESS_MODE        enforce | learn | (unset → noop)
#   /etc/boring/egress.allow  one hostname per line, RO bind-mount from host
#
# Failure mode: if BORING_EGRESS_MODE=enforce and rule install fails, we exit
# non-zero — better to fail loud than ship a container that thinks it's
# protected but isn't. learn-mode failures degrade to warnings.
#
# After installing rules, capabilities are dropped via `gosu dev` — the dev
# user cannot mutate iptables to weaken policy.

set -eu

MODE="${BORING_EGRESS_MODE:-}"
ALLOW_FILE="${BORING_EGRESS_ALLOW_FILE:-/etc/boring/egress.allow}"
# ARD-0036 cross_sandbox: the profile's declared sidecar service names (ARD-0007),
# passed through by lib/compose.sh as a space/comma-separated list. Each is
# resolved to its container IP and ACCEPTed before the rest of $NET_CIDR drops.
SIDECARS="${BORING_EGRESS_SIDECARS:-}"
# ARD-0015: learn mode logs via NFLOG (userspace netfilter logger) instead of
# kernel LOG. ulogd2 in the egress-logger sidecar binds NFLOG group 5 on the
# shared netns and writes JSON-Lines. The prefix is a bare string (no
# brackets) — NFLOG truncates at 32 chars and we want the raw token for
# pattern matching at log-parse time.
NFLOG_GROUP="${BORING_EGRESS_NFLOG_GROUP:-5}"
NFLOG_PREFIX="boring-egress-attempt"
FIFO="${BORING_EVENTS_FIFO:-/var/log/boring/events.fifo}"

log() { printf '[install-egress] %s\n' "$*" >&2; }

emit_event() {
  # JSON-Lines event to ARD-0010 FIFO if it exists, else stderr.
  # Wrap with `timeout` to avoid blocking forever on a FIFO with no reader
  # (POSIX open-for-write blocks until a reader exists). When ARD-0010 lands
  # the FIFO will have a reader; until then, the 1s timeout falls back to
  # stderr without stalling boot.
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  evt="{\"ts\":\"$ts\",\"kind\":\"$1\",\"msg\":\"$2\"}"
  if [ -p "$FIFO" ] && command -v timeout >/dev/null 2>&1; then
    if ! printf '%s\n' "$evt" | timeout 1 dd of="$FIFO" status=none 2>/dev/null; then
      printf '%s\n' "$evt" >&2
    fi
  else
    printf '%s\n' "$evt" >&2
  fi
}

if [ -z "$MODE" ]; then
  # Egress unconfigured for this profile — passthrough.
  exec gosu dev "$@"
fi

if [ "$MODE" != "enforce" ] && [ "$MODE" != "learn" ] && [ "$MODE" != "unsafe" ]; then
  log "unknown BORING_EGRESS_MODE='$MODE' (want enforce|learn|unsafe) — failing closed"
  exit 2
fi

if ! command -v iptables >/dev/null 2>&1; then
  log "iptables not installed in image — cannot enforce egress"
  exit 2
fi

# Detect compose-network CIDR. The container's eth0 is on the compose-managed
# bridge; `ip route` shows it as the first non-default route. Falls back to
# 172.16.0.0/12 (Docker's default private range) if detection fails.
NET_CIDR="$(ip route 2>/dev/null | awk '/dev eth0/ && $1 != "default" {print $1; exit}')"
if [ -z "$NET_CIDR" ]; then
  log "could not detect compose network CIDR; falling back to 172.16.0.0/12"
  NET_CIDR="172.16.0.0/12"
fi

# Choose the tail action — REJECT for enforce, NFLOG (audit-only, ARD-0015)
# for learn. NFLOG ships matched packets to the ulogd2 sidecar via the
# netfilter netlink socket; kernel LOG was the v0.3 path but doesn't reach
# the sidecar inside Orbstack / Docker-for-Mac VMs.
case "$MODE" in
  enforce) TAIL_RULE="-j REJECT --reject-with icmp-net-prohibited" ;;
  learn)   TAIL_RULE="-j NFLOG --nflog-group $NFLOG_GROUP --nflog-prefix $NFLOG_PREFIX" ;;
  unsafe)  TAIL_RULE="" ;;  # default-ACCEPT; only the ARD-0036 floor blocks
esac

# ARD-0036 baseline floor (subset): cloud-metadata + link-local, dropped
# UNCONDITIONALLY in every mode — including --unsafe-network. This is the
# single highest-value SSRF/credential-theft target (169.254.169.254 et al),
# named in ARD-0011 as the reason egress exists. The DNS resolver is carved out
# first so name resolution survives if it happens to sit on a link-local IP.
# NOTE: the other ARD-0036 categories (cross_sandbox/$NET_CIDR, smtp,
# ssh_except_git) are deferred — they need sidecar/git-host carve-outs and
# in-container verification before they can ship without breaking connectivity.
install_floor_v4() {
  for r in $(awk '/^[[:space:]]*nameserver/ {print $2}' /etc/resolv.conf 2>/dev/null); do
    case "$r" in 169.254.*) iptables -A OUTPUT -d "$r" -j ACCEPT ;; esac
  done
  iptables -A OUTPUT -d 169.254.169.254/32 -j DROP   # AWS / GCP IMDS
  iptables -A OUTPUT -d 169.254.170.2/32   -j DROP   # ECS task metadata
  iptables -A OUTPUT -d 169.254.0.0/16     -j DROP   # link-local (covers the above)
}
install_floor_v6() {
  ip6tables -A OUTPUT -d fd00:ec2::254/128 -j DROP 2>/dev/null || true  # EC2 IMDSv6
  ip6tables -A OUTPUT -d fe80::/10         -j DROP 2>/dev/null || true  # link-local
}

# Resolver IPs from /etc/resolv.conf, one per line. The resolver is carved out
# of both cross_sandbox and RFC1918 drops so name resolution survives even when
# the resolver sits inside the docker subnet (the common compose case) or a
# private range.
resolver_ips() { awk '/^[[:space:]]*nameserver/ {print $2}' /etc/resolv.conf 2>/dev/null; }

# ARD-0036 cross_sandbox + RFC1918 carve-outs (enforce + learn only; never
# unsafe). Returns 0 if the drops were installed, 1 if a declared sidecar could
# not be resolved. On a resolution failure we FAIL OPEN: the caller skips the
# drops for this run rather than risk severing dev → postgres/redis. Better a
# wide-open subnet than a silently-broken multi-service profile.
#
# Order within the chain: sidecar + resolver ACCEPTs first, then the
# cross_sandbox ($NET_CIDR) DROP, then the three RFC1918 DROPs. install_v4 runs
# the allowlist loop just above this call, so any allowlisted host that resolves
# into a private range is already ACCEPTed and beats these drops.
install_cross_sandbox_v4() {
  for r in $(resolver_ips); do
    case "$r" in *.*) iptables -A OUTPUT -d "$r" -j ACCEPT ;; esac
  done
  for svc in $(printf '%s' "$SIDECARS" | tr ',' ' '); do
    [ -z "$svc" ] && continue
    ips="$(getent ahostsv4 "$svc" 2>/dev/null | awk '{print $1}' | sort -u)"
    if [ -z "$ips" ]; then
      log "warning: could not resolve sidecar '$svc' (v4); skipping cross_sandbox/RFC1918 drops this run (fail-open)"
      return 1
    fi
    for ip in $ips; do
      iptables -A OUTPUT -d "$ip" -j ACCEPT
    done
  done
  iptables -A OUTPUT -d "$NET_CIDR" -j DROP            # cross_sandbox: rest of docker subnet
  iptables -A OUTPUT -d 10.0.0.0/8     -j DROP         # RFC1918
  iptables -A OUTPUT -d 172.16.0.0/12  -j DROP         # RFC1918
  iptables -A OUTPUT -d 192.168.0.0/16 -j DROP         # RFC1918 (host LAN — ARD-0042)
  return 0
}

install_v4() {
  iptables -F OUTPUT
  iptables -P OUTPUT ACCEPT  # safe baseline while we install; tail-rule decides final fate
  # ARD-0036 floor FIRST so a deny beats every later ACCEPT (allowlist AND the
  # unsafe-mode default-accept).
  install_floor_v4
  # --unsafe-network: everything else is allowed (default policy ACCEPT). Only
  # the floor above blocks. No allowlist, no tail REJECT.
  if [ "$MODE" = "unsafe" ]; then
    return 0
  fi
  iptables -A OUTPUT -o lo -j ACCEPT
  iptables -A OUTPUT -p udp --dport 53 -j ACCEPT
  iptables -A OUTPUT -p tcp --dport 53 -j ACCEPT
  # Allow established/related so return traffic for already-accepted flows works.
  iptables -A OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

  if [ -r "$ALLOW_FILE" ]; then
    while IFS= read -r host; do
      # Skip blanks and comments.
      case "$host" in ''|\#*) continue ;; esac
      # getent ahostsv4 returns "<ip> STREAM <host>" lines; dedupe IPs.
      ips="$(getent ahostsv4 "$host" 2>/dev/null | awk '{print $1}' | sort -u)"
      if [ -z "$ips" ]; then
        log "warning: could not resolve $host (v4); skipping"
        continue
      fi
      for ip in $ips; do
        iptables -A OUTPUT -d "$ip" -j ACCEPT
      done
    done < "$ALLOW_FILE"
  fi

  # ARD-0036 cross_sandbox + RFC1918. Comes after the allowlist (so an
  # allowlisted private host is already ACCEPTed and beats the drop) but before
  # the tail. Fails open if a declared sidecar won't resolve — see helper.
  install_cross_sandbox_v4 || true

  # shellcheck disable=SC2086  # TAIL_RULE intentionally word-split
  iptables -A OUTPUT $TAIL_RULE
}

install_v6() {
  # IPv6 may not be available (Orbstack often disables it inside containers).
  # If ip6tables isn't usable, log and skip — leaving v6 unconfigured is fine
  # when v6 isn't routable in the first place.
  if ! ip6tables -L >/dev/null 2>&1; then
    log "ip6tables unavailable; skipping IPv6 rule install (likely no v6 in container)"
    return 0
  fi
  ip6tables -F OUTPUT
  ip6tables -P OUTPUT ACCEPT
  install_floor_v6
  if [ "$MODE" = "unsafe" ]; then
    return 0
  fi
  ip6tables -A OUTPUT -o lo -j ACCEPT
  ip6tables -A OUTPUT -p udp --dport 53 -j ACCEPT
  ip6tables -A OUTPUT -p tcp --dport 53 -j ACCEPT
  ip6tables -A OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

  if [ -r "$ALLOW_FILE" ]; then
    while IFS= read -r host; do
      case "$host" in ''|\#*) continue ;; esac
      ips="$(getent ahostsv6 "$host" 2>/dev/null | awk '{print $1}' | sort -u)"
      [ -z "$ips" ] && continue
      for ip in $ips; do
        ip6tables -A OUTPUT -d "$ip" -j ACCEPT
      done
    done < "$ALLOW_FILE"
  fi

  # shellcheck disable=SC2086
  ip6tables -A OUTPUT $TAIL_RULE
}

log "mode=$MODE  net_cidr=$NET_CIDR  allow_file=$ALLOW_FILE"
if ! install_v4; then
  log "failed to install IPv4 rules"
  emit_event egress_install_failed "ipv4 rule install failed"
  exit 3
fi
install_v6 || log "IPv6 rule install failed (continuing — v4 is the load-bearing path)"

emit_event egress_installed "mode=$MODE net=$NET_CIDR"

# Drop privileges and exec the original command. gosu clears capabilities by
# default — the dev user has no CAP_NET_ADMIN and cannot mutate iptables.
if ! command -v gosu >/dev/null 2>&1; then
  log "gosu not installed; refusing to run user code as root"
  exit 2
fi
exec gosu dev "$@"
