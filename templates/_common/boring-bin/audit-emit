#!/bin/sh
# audit-emit — in-container audit event emitter (ARD-0010).
#
# Wrap whatever the caller hands us (stdin payload OR command-line args) in
# the boring JSON envelope and write one line to the audit FIFO. Three
# Claude Code hooks (UserPromptSubmit, PostToolUse, Stop) invoke this through
# per-kind symlinks (audit-emit-prompt_issued, audit-emit-tool_used,
# audit-emit-prompt_completed) — the basename of $0 carries the kind.
#
# Trust-anchor surface (ARD-0006 + ARD-0009 pattern, ARD-0010 derived):
#   This script + per-kind symlinks are emitted host-side at `boring open`
#   time into <repo>/.devcontainer/boring-runtime/bin/, then bind-mounted
#   READ-ONLY into the container at /workspace/.devcontainer/boring-runtime/bin/.
#   The container cannot modify them regardless of sudo — the read-only
#   bind-mount is enforced by the docker daemon, not by file permissions.
#   This is the same trust-anchor pattern that protects .boring/* (ARD-0006)
#   and the pre-push hook + command wrappers (ARD-0009). The Claude `deny`
#   rule on /workspace/.devcontainer/boring-runtime/** catches Claude-via-tool
#   attempts before they hit the kernel-level refusal — defense in depth.
#
# Failure modes:
#   - FIFO missing (collector down): we still try to write; the write fails
#     silently. We exit 0 because an audit failure should never block the
#     wrapped hook's actual behavior (Claude would interpret a non-zero
#     hook exit as a tool refusal, which is much worse than a dropped audit
#     event).
#   - Malformed input: we still emit the envelope with `details: {}` so the
#     event-occurred fact survives even when the payload is unparseable.

FIFO="/var/log/boring/events.fifo"

# Derive kind: prefer $0 basename suffix (when invoked through audit-emit-<kind>
# symlink); fall back to $1 (when invoked directly as `audit-emit <kind>`).
self="$(basename "$0")"
case "$self" in
  audit-emit-*) kind="${self#audit-emit-}" ;;
  *)            kind="${1:-unknown}" ;;
esac

# Read stdin (Claude hooks deliver JSON on stdin); cap at a sane size to avoid
# a runaway emission filling the FIFO buffer in a single line. 64 KiB is the
# rough threshold beyond which we'd want to truncate-and-mark anyway.
payload="$(head -c 65536 2>/dev/null || true)"

# Build envelope. If `jq` is available (it is in both presets per their
# Dockerfiles), we use it to construct valid JSON. If not, we hand-construct
# with very basic escaping (the payload is the only untrusted field — we put
# it in details verbatim only when it's valid JSON; otherwise as a string).
ts="$(date -u +%Y-%m-%dT%H:%M:%S.000Z)"
profile="${BORING_PROFILE_NAME:-unknown}"
user="${BORING_HOST_USER:-${USER:-unknown}}"
# ARD-0027: every event carries the agent that produced it so `boring audit
# --agent` can filter by harness. This shim is invoked by Claude Code's hooks,
# so it defaults to claude; BORING_AGENT lets another harness override it.
agent="${BORING_AGENT:-claude}"

if command -v jq >/dev/null 2>&1; then
  # Try to parse payload as JSON; if it parses, embed as a JSON object/value,
  # else embed as a string in details.raw.
  if printf '%s' "$payload" | jq -e . >/dev/null 2>&1; then
    envelope="$(jq -nc \
      --arg ts "$ts" --arg kind "$kind" --arg profile "$profile" --arg user "$user" --arg agent "$agent" \
      --argjson details "${payload:-{\}}" \
      '{ts:$ts, kind:$kind, profile:$profile, user:$user, agent:$agent, details:$details}')"
  else
    envelope="$(jq -nc \
      --arg ts "$ts" --arg kind "$kind" --arg profile "$profile" --arg user "$user" --arg agent "$agent" \
      --arg raw "$payload" \
      '{ts:$ts, kind:$kind, profile:$profile, user:$user, agent:$agent, details:{raw:$raw}}')"
  fi
else
  # Fallback (image without jq — shouldn't happen but defensive). Strip
  # newlines + quotes from payload, embed as raw string. Lossy but safe.
  safe="$(printf '%s' "$payload" | tr -d '\n\r' | sed 's/"/\\"/g')"
  envelope="{\"ts\":\"$ts\",\"kind\":\"$kind\",\"profile\":\"$profile\",\"user\":\"$user\",\"agent\":\"$agent\",\"details\":{\"raw\":\"$safe\"}}"
fi

# Write atomically: one printf, single FD, no flushing concerns at this size.
# Redirect failures to /dev/null so the hook never fails on audit loss.
printf '%s\n' "$envelope" >> "$FIFO" 2>/dev/null || true
exit 0
